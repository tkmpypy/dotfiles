initial-command = "fish"

theme = dark:Onenord,light:Onenord light

font-family = JetBrains Mono
font-family = "UDEV Gothic NF"
font-size = 12
font-thicken
font-thicken-strength = 5
font-feature = -dlig

minimum-contrast = 1.0

# 外部アプリからクリップボード内容を読み取ることを許可
clipboard-read = allow

# ターミナルからクリップボードへ書き込むことを許可
clipboard-write = allow
